# Copy this file to .env and fill in your values.

# PostgreSQL 
POSTGRES_DB=mydb
POSTGRES_USER=pastgres
POSTGRES_PASSWORD=pastgres
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Ports
# BACKEND_PORT is for bare-metal dev only (e.g. when 4000 is taken on your
# machine). In Docker deployments DO NOT change it — the container-internal
# ports are a fixed contract (frontend 3000, backend 4000): pm2.config.cjs,
# AGENT_RUNTIME_PROXY_HOST (http://app:4000), and the Dockerfile EXPOSE lines
# all assume 4000. 
BACKEND_PORT=4000
# FRONTEND_PORT only changes the published HOST port in
# docker-compose; inside the container the frontend always listens on 3000.
FRONTEND_PORT=3000

# Number of reverse proxy hops in front of the backend (0 = no proxy / local dev,
# 1 = one nginx/load-balancer hop in production). Must be a number 
TRUST_PROXY_HOPS=0

# Allowed CORS origins (comma-separated, default: http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:3000

# Global rate limiter, applied per client IP (see middleware/auth.ts).
# RATE_LIMIT_WINDOW_MS = window length in milliseconds (default 60000 = 1 minute)
# RATE_LIMIT_MAX       = max requests allowed per window (default 2000)
# Invalid / non-positive values fall back to the defaults.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500

# 32-byte hex string for AES-256-GCM credential encryption and API key encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# JWT signing secret (any long random string, min 32 chars recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT lifetime, e.g. 7d, 1h, 30m
JWT_EXPIRES_IN=7d

# Public-facing application URL (used as the OAuth2 redirect base, and the base
# for app-trigger webhook delivery URLs: ${APP_URL}/api/v1/webhooks/<triggerId>).
# In production, this is your deployed frontend domain.
APP_URL=http://localhost:3000

# ── App Triggers ──────────────────────────────────────────────────────────────

# Default Google Cloud Pub/Sub topic for the Gmail app trigger (users.watch).
# Full resource name: projects/<project>/topics/<topic>. Optional — a Gmail trigger
# can override it per-trigger. Grant publish to gmail-api-push@system.gserviceaccount.com
# and add a Pub/Sub push subscription pointing at the trigger's delivery URL.
GOOGLE_PUBSUB_TOPIC=

# ── Agent Runtime ─────────────────────────────────────────────────────────────

# Secret for signing PROXY_TOKEN JWTs issued to agent child processes.
# Must be separate from JWT_SECRET — these tokens are short-lived (15 min) and
# scoped to one agent/thread/credential set.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROXY_TOKEN_SECRET=

# Absolute path to the compiled agent-runtime entrypoint (dist/index.js).
# AgentRuntimeService spawns this file as a Node.js child process per agent turn.
# Default (relative to repo root): apps/agent-runtime/dist/index.js
# In production Docker, set to the absolute path inside the container, e.g.:
#   AGENT_RUNTIME_ENTRY=/repo/apps/agent-runtime/dist/index.js
AGENT_RUNTIME_ENTRY=

# Absolute path to the base directory for per-agent persistent workspaces.
# Each agent gets a subdirectory: <AGENT_WORKSPACES_PATH>/<agentId>/
# The agent process has read/write access only to its own subdirectory.
# Default (relative to repo root): .agent-workspaces
# In production, use an absolute path outside the repo, e.g. /opt/agent-workspaces
AGENT_WORKSPACES_PATH=

# ── Agent Runtime Isolation (execution driver) ────────────────────────────────

# How agent runtimes are executed:
#   process (default) — plain Node.js child process. Code-level isolation only:
#                       no OS boundary between the agent and the host.
#   docker            — one hardened sibling Docker container per agent turn
#                       (recommended; docker-compose sets this automatically).
#                       Namespaces, read-only rootfs, non-root user, resource
#                       limits, and per-agent network egress policy.
AGENT_RUNTIME_DRIVER=process

# Runtime container image (docker driver). Build with:
#   docker compose --profile build build agent-runtime
AGENT_RUNTIME_IMAGE=logiclabshq/agent-runtime:latest

# URL the runtime container uses to reach the backend proxy endpoints.
# docker-compose sets http://app:4000 (compose service name). For bare-metal
# dev with the docker driver, use http://host.docker.internal:4000.
AGENT_RUNTIME_PROXY_HOST=

# Docker networks for runtime containers (created automatically if missing).
# Agents with "Allow internet access" ON run on AGENT_RUNTIME_NETWORK (normal
# egress); agents with it OFF run on AGENT_RUNTIME_NETWORK_INTERNAL (can only
# reach the backend — credential-proxied call_api still works).
# OPTIONAL: when the backend runs as a container these are auto-detected from the
# networks the backend itself is attached to (so they self-correct under a
# renaming orchestrator like Coolify/Dokploy). Set them only to override.
AGENT_RUNTIME_NETWORK=openagent_runtime
AGENT_RUNTIME_NETWORK_INTERNAL=openagent_runtime_internal

# Set to true on LINUX bare-metal dev so the runtime container can resolve
# host.docker.internal (adds the host-gateway extra host). Docker Desktop and
# OrbStack on macOS resolve it natively.
AGENT_RUNTIME_ADD_HOST_GATEWAY=false

# Workspace mounting for the docker driver.
# OPTIONAL when the backend runs as a container: the driver auto-detects whichever
# volume (or bind) actually backs AGENT_WORKSPACES_PATH on the backend container,
# so this self-corrects under a renaming orchestrator (Coolify/Dokploy). Set one
# explicitly only to override, or when the backend is NOT containerised:
#   AGENT_RUNTIME_WORKSPACE_VOLUME    — name of the docker named volume holding
#                                       all agent workspaces (production; per-
#                                       agent subpath mounts need Docker >= 26).
#   AGENT_RUNTIME_WORKSPACE_HOST_PATH — absolute HOST path of the workspaces
#                                       dir (bare-metal dev bind mounts).
AGENT_RUNTIME_WORKSPACE_VOLUME=AGENT_RUNTIME_DOCKER_RUNTIME
AGENT_RUNTIME_WORKSPACE_HOST_PATH=

# Hard wall-clock limit per agent run in ms (applies to BOTH drivers).
# Default 2400000 (40 min) — must exceed the 35-min ask_human long-poll window.
AGENT_RUNTIME_TIMEOUT_MS=2400000

# Maximum simultaneous agent runs across all agents (applies to BOTH drivers).
AGENT_RUNTIME_MAX_CONCURRENT=20

# Per-container resource limits (docker driver).
AGENT_RUNTIME_MEMORY_LIMIT_MB=1024
AGENT_RUNTIME_CPU_LIMIT=1
AGENT_RUNTIME_PIDS_LIMIT=256

# Optional alternate OCI runtime for the runtime containers, e.g. "runsc" to
# run them under gVisor (Linux hosts with gVisor installed on the daemon).
AGENT_RUNTIME_DOCKER_RUNTIME=

# ─── Browser Tool ─────────────────────────────────────────────────────────────
#
# Lets agents drive a real headless browser (navigate, fill forms, click, read
# pages, screenshot) WITHOUT running the browser inside the agent sandbox. The
# browser runs in a separate, host-managed container (production) or in-process
# in the backend (bare-metal dev). Browser tools are HARD-gated: an agent can use
# them only when its "Allow internet access" setting is ON (enforced server-side
# by a live DB check on every browser action), and only when the feature is
# enabled here.
#
# MASTER SWITCH — default false. When false/unset the whole feature is off: no
# browser image is pulled, no container is started, and browser tools are not
# offered to ANY agent. Set to true to enable.
BROWSER_FEATURE_ENABLED=false

# Provider mode: auto | container | local. `auto` picks `container` when the
# backend runs the docker execution driver (production), else `local`
# (in-process Chromium via the full `playwright` package — for bare-metal/test;
# run `pnpm --filter @repo/backend exec playwright install chromium` once).
BROWSER_MODE=auto

# Local-mode only (BROWSER_MODE=local): use an EXISTING browser binary instead of
# running `playwright install`. Set ONE of these to point at a chromium/chrome you
# already have. Ignored in container mode.
BROWSER_LOCAL_EXECUTABLE_PATH=
# e.g. "chrome" to use an installed Google Chrome, "msedge" for Edge.
BROWSER_LOCAL_CHANNEL=

# Container-mode browser image. Must expose a CDP/WebSocket endpoint on
# BROWSER_CONTAINER_PORT. The backend pulls it (only when the feature is enabled)
# and launches it on BROWSER_NETWORK.
BROWSER_IMAGE=ghcr.io/browserless/chromium:latest
BROWSER_CONTAINER_PORT=3000
# Connection protocol to the browser: cdp (connectOverCDP, default) | ws (Playwright server).
BROWSER_CONNECT_MODE=cdp
# Optional token some browser images require (passed as TOKEN env + ?token= on connect).
BROWSER_TOKEN=
# Dedicated docker network for the browser container — agents are never attached
# to it, so a shared browser cannot leak one agent's cookies to another. The
# backend must be attached (docker-compose.yml does this).
BROWSER_NETWORK=openagent_browser
# Optional: connect to an externally-managed browser instead of launching one.
# When set, the backend does NOT launch/pull a container.
BROWSER_WS_ENDPOINT=

# Per-container resource limits for the browser (container mode).
BROWSER_MEMORY_LIMIT_MB=1024
BROWSER_CPU_LIMIT=1
BROWSER_PIDS_LIMIT=512

# Max simultaneous browser sessions (one isolated context per active thread).
BROWSER_MAX_CONCURRENT_SESSIONS=10
# The browser stays open across turns of a conversation. It is closed when the
# thread is deleted, after this idle timeout (ms, no activity), or at the hard
# max-lifetime cap below — whichever comes first. State is saved before closing.
BROWSER_SESSION_IDLE_TIMEOUT_MS=300000
# Absolute max lifetime (ms) of a browser session regardless of activity.
BROWSER_SESSION_MAX_LIFETIME_MS=1800000
# Per-action / per-navigation Playwright timeouts (ms).
BROWSER_ACTION_TIMEOUT_MS=15000
BROWSER_NAVIGATION_TIMEOUT_MS=30000

# Backend-only directory for persisted browser session state (cookies +
# localStorage, per agent). MUST NOT be under AGENT_WORKSPACES_PATH — it is never
# mounted into a runtime, so agents cannot read their own session cookies.
# Default: a repo-root sibling (.agent-browser-state). In docker-compose this is
# a dedicated volume at /opt/agent-browser-state.
AGENT_BROWSER_STATE_PATH=

# ─── Skills ───────────────────────────────────────────────────────────────────

# Optional GitHub token used when installing skills from GitHub repositories.
# Unauthenticated requests are limited to 60/hour by GitHub — set a token
# (classic or fine-grained, public repo read access only) to raise the limit.
GITHUB_TOKEN=

# File-type policy for user-installed skills. Comma-separated allowlist of file
# extensions (without the leading dot). Files with any other extension are
# filtered out of the skill bundle and the user is told at install review.
# `md` is always implicitly allowed since SKILL.md is required. Binary files are
# always rejected regardless of extension. Default: md,txt
SKILL_INSTALL_ALLOWED_FILE_EXT=md,txt

# Skill evolution engine (GEPA-style background worker).
# Set SKILL_EVOLUTION_ENABLED=false to disable entirely.
SKILL_EVOLUTION_ENABLED=true
# Cron schedule for evolution cycles (default: every 6 hours).
SKILL_EVOLUTION_CRON=0 */6 * * *
# Minimum fresh traces per (agent, skill) pair before a reflection is attempted.
SKILL_EVOLUTION_MIN_TRACES=5
# Without any failed traces, require this many traces before evolving anyway.
SKILL_EVOLUTION_MIN_TRACES_NO_FAILURE=10
# Hard cap on reflection LLM calls per cycle.
SKILL_EVOLUTION_MAX_PER_CYCLE=10
# Execution traces older than this many days are deleted each cycle.
SKILL_TRACE_RETENTION_DAYS=30
