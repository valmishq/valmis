# Copy this file to .env and fill in your values.

# PostgreSQL 
POSTGRES_DB=mydb
POSTGRES_USER=pastgres
POSTGRES_PASSWORD=pastgres
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Ports
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Number of reverse proxy hops in front of the backend (0 = no proxy / local dev,
# 1 = one nginx/load-balancer hop in production). Must be a number 
TRUST_PROXY_HOPS=0

# Allowed CORS origins (comma-separated, default: http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:3000

# 32-byte hex string for AES-256-GCM credential encryption and API key encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# JWT signing secret (any long random string, min 32 chars recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT lifetime, e.g. 7d, 1h, 30m
JWT_EXPIRES_IN=7d

# Public-facing application URL (used as the OAuth2 redirect base).
# In production, this is your deployed frontend domain.
APP_URL=http://localhost:3000

# ── Agent Runtime ─────────────────────────────────────────────────────────────

# Secret for signing PROXY_TOKEN JWTs issued to agent child processes.
# Must be separate from JWT_SECRET — these tokens are short-lived (15 min) and
# scoped to one agent/thread/credential set.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROXY_TOKEN_SECRET=

# Absolute path to the compiled agent-runtime entrypoint (dist/index.js).
# AgentRuntimeService spawns this file as a Node.js child process per agent turn.
# Default (relative to repo root): apps/agent-runtime/dist/index.js
# In production Docker, set to the absolute path inside the container, e.g.:
#   AGENT_RUNTIME_ENTRY=/repo/apps/agent-runtime/dist/index.js
AGENT_RUNTIME_ENTRY=

# Absolute path to the base directory for per-agent persistent workspaces.
# Each agent gets a subdirectory: <AGENT_WORKSPACES_PATH>/<agentId>/
# The agent process has read/write access only to its own subdirectory.
# Default (relative to repo root): .agent-workspaces
# In production, use an absolute path outside the repo, e.g. /opt/agent-workspaces
AGENT_WORKSPACES_PATH=
