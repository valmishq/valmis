# Copy this file to .env and fill in your values.

# PostgreSQL 
POSTGRES_DB=mydb
POSTGRES_USER=pastgres
POSTGRES_PASSWORD=pastgres
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Ports
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Number of reverse proxy hops in front of the backend (0 = no proxy / local dev,
# 1 = one nginx/load-balancer hop in production). Must be a number 
TRUST_PROXY_HOPS=0

# Allowed CORS origins (comma-separated, default: http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:3000

# 32-byte hex string for AES-256-GCM credential encryption and API key encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=

# JWT signing secret (any long random string, min 32 chars recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT lifetime, e.g. 7d, 1h, 30m
JWT_EXPIRES_IN=7d

# Public-facing application URL (used as the OAuth2 redirect base).
# In production, this is your deployed frontend domain.
APP_URL=http://localhost:3000

# ── Agent Runtime ─────────────────────────────────────────────────────────────

# Secret for signing PROXY_TOKEN JWTs issued to agent child processes.
# Must be separate from JWT_SECRET — these tokens are short-lived (15 min) and
# scoped to one agent/thread/credential set.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROXY_TOKEN_SECRET=

# Absolute path to the compiled agent-runtime entrypoint (dist/index.js).
# AgentRuntimeService spawns this file as a Node.js child process per agent turn.
# Default (relative to repo root): apps/agent-runtime/dist/index.js
# In production Docker, set to the absolute path inside the container, e.g.:
#   AGENT_RUNTIME_ENTRY=/repo/apps/agent-runtime/dist/index.js
AGENT_RUNTIME_ENTRY=

# Absolute path to the base directory for per-agent persistent workspaces.
# Each agent gets a subdirectory: <AGENT_WORKSPACES_PATH>/<agentId>/
# The agent process has read/write access only to its own subdirectory.
# Default (relative to repo root): .agent-workspaces
# In production, use an absolute path outside the repo, e.g. /opt/agent-workspaces
AGENT_WORKSPACES_PATH=

# ── Agent Runtime Isolation (execution driver) ────────────────────────────────

# How agent runtimes are executed:
#   process (default) — plain Node.js child process. Code-level isolation only:
#                       no OS boundary between the agent and the host.
#   docker            — one hardened sibling Docker container per agent turn
#                       (recommended; docker-compose sets this automatically).
#                       Namespaces, read-only rootfs, non-root user, resource
#                       limits, and per-agent network egress policy.
AGENT_RUNTIME_DRIVER=process

# Runtime container image (docker driver). Build with:
#   docker compose --profile build build agent-runtime
AGENT_RUNTIME_IMAGE=logiclabshq/agent-runtime:latest

# URL the runtime container uses to reach the backend proxy endpoints.
# docker-compose sets http://app:4000 (compose service name). For bare-metal
# dev with the docker driver, use http://host.docker.internal:4000.
AGENT_RUNTIME_PROXY_HOST=

# Docker networks for runtime containers (created automatically if missing).
# Agents with "Allow internet access" ON run on AGENT_RUNTIME_NETWORK (normal
# egress); agents with it OFF run on AGENT_RUNTIME_NETWORK_INTERNAL (can only
# reach the backend — credential-proxied call_api still works).
AGENT_RUNTIME_NETWORK=openagent_runtime
AGENT_RUNTIME_NETWORK_INTERNAL=openagent_runtime_internal

# Set to true on LINUX bare-metal dev so the runtime container can resolve
# host.docker.internal (adds the host-gateway extra host). Docker Desktop and
# OrbStack on macOS resolve it natively.
AGENT_RUNTIME_ADD_HOST_GATEWAY=false

# Workspace mounting for the docker driver — set exactly one:
#   AGENT_RUNTIME_WORKSPACE_VOLUME    — name of the docker named volume holding
#                                       all agent workspaces (production; per-
#                                       agent subpath mounts need Docker >= 26).
#   AGENT_RUNTIME_WORKSPACE_HOST_PATH — absolute HOST path of the workspaces
#                                       dir (bare-metal dev bind mounts).
AGENT_RUNTIME_WORKSPACE_VOLUME=
AGENT_RUNTIME_WORKSPACE_HOST_PATH=

# Hard wall-clock limit per agent run in ms (applies to BOTH drivers).
# Default 2400000 (40 min) — must exceed the 35-min ask_human long-poll window.
AGENT_RUNTIME_TIMEOUT_MS=2400000

# Maximum simultaneous agent runs across all agents (applies to BOTH drivers).
AGENT_RUNTIME_MAX_CONCURRENT=20

# Per-container resource limits (docker driver).
AGENT_RUNTIME_MEMORY_LIMIT_MB=1024
AGENT_RUNTIME_CPU_LIMIT=1
AGENT_RUNTIME_PIDS_LIMIT=256

# Optional alternate OCI runtime for the runtime containers, e.g. "runsc" to
# run them under gVisor (Linux hosts with gVisor installed on the daemon).
AGENT_RUNTIME_DOCKER_RUNTIME=
