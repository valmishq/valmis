# Dependencies — reinstalled inside the image
**/node_modules

# Build outputs — compiled inside the image
**/dist
**/.svelte-kit
**/build

# Turbo cache
.turbo

# Env files — NEVER enter the build context. The build is environment-agnostic;
# all env vars are injected at runtime via docker-compose env_file. Both
# Dockerfiles run `COPY . .`, so anything not listed here lands in image layers.
.env
.env.*
*.local

# Git
.git
.gitignore

# Docs and dev notes
.dev
README.md

# Test files
**/*.test.ts
**/*.spec.ts

# Editor
.vscode
.idea

# OS
.DS_Store
Thumbs.db

# Agent workspaces (live on host, not in image)
agent-workspaces
